# =============================================================
# Local Docker Compose environment
# Copy this to .env and adjust values
# =============================================================

# App
APP_NAME="Todo Swarm"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_VERSION=1.0.0

# Database
DB_ROOT_PASSWORD=rootsecret
DB_DATABASE=todo_db
DB_USERNAME=todo_user
DB_PASSWORD=secret

# Redis
REDIS_PASSWORD=

# Docker Hub (for pushing images — Phase 2+)
DOCKER_HUB_USER=thorthedev
IMAGE_NAME=todo-swarm-app
IMAGE_TAG=latest
